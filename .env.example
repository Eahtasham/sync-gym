# Copy to .env and fill in.

# Supabase Postgres — app connection (transaction-mode pooler, port 6543).
DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — migrations connection (session-mode pooler, port 5432).
DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>.pooler.supabase.com:5432/postgres"

# Secret protecting the daily cron cleanup endpoint.
CRON_SECRET="change-me"

# Signs PIN session cookies + hashes PINs.
AUTH_SECRET="change-me"

# App timezone (server clock). Set the same value in Vercel env vars.
TZ="Asia/Kolkata"
