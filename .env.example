# Copy to .env and fill in.

# Local dev: SQLite file (used by the Prisma CLI). Run `npm run db:push`.
DATABASE_URL="file:./dev.db"

# Production: Turso (libSQL). Set BOTH to use Turso instead of the local file.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Secret protecting the daily cron cleanup endpoint.
CRON_SECRET="change-me"
