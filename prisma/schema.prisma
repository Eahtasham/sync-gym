// Gym Workout Tracker — Prisma schema (Supabase Postgres)
// Two-user app: workout-day/exercise templates are SHARED; sessions, sets,
// cardio and bodyweight logs belong to a user. Workout logs expire after 30 days.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; rhel-openssl-3.0.x is the engine Vercel's runtime needs.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// An app user (profile). Auth is a per-user 4-digit PIN.
model User {
  id            String           @id @default(cuid())
  name          String
  pinHash       String?
  weeklyGoal    Int              @default(5)
  displayOrder  Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sessions      WorkoutSession[]
  bodyweightLogs BodyweightLog[]

  @@index([displayOrder])
}

/// A reusable workout template, e.g. "Chest Day". Shared across users.
model WorkoutDay {
  id           String           @id @default(cuid())
  name         String
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  exercises    Exercise[]
  sessions     WorkoutSession[]

  @@index([displayOrder])
}

/// An exercise belonging to a workout day. Strength or cardio. Shared.
model Exercise {
  id           String        @id @default(cuid())
  workoutDayId String
  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  name         String
  type         String        @default("STRENGTH") // "STRENGTH" | "CARDIO"
  displayOrder Int           @default(0)
  isFavorite   Boolean       @default(false)
  postureUrl   String?       // optional link to a correct-posture demo/video
  createdAt    DateTime      @default(now())
  logs         ExerciseLog[]
  cardioLogs   CardioLog[]

  @@index([workoutDayId, displayOrder])
}

/// A single performed workout, owned by a user. `createdAt` drives 30-day expiry.
model WorkoutSession {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDayId String
  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  sessionDate  DateTime      @default(now())
  notes        String?
  createdAt    DateTime      @default(now())
  exerciseLogs ExerciseLog[]
  cardioLogs   CardioLog[]

  @@index([userId, sessionDate])
  @@index([workoutDayId])
  @@index([createdAt])
}

/// One exercise performed within a session (groups its sets).
model ExerciseLog {
  id               String         @id @default(cuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exerciseId       String
  exercise         Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  notes            String?
  sets             ExerciseSet[]

  @@index([workoutSessionId])
  @@index([exerciseId])
}

/// A single set: weight (kg) x reps.
model ExerciseSet {
  id            String      @id @default(cuid())
  exerciseLogId String
  exerciseLog   ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)
  setNumber     Int
  weight        Float       @default(0)
  reps          Int         @default(0)

  @@index([exerciseLogId])
}

/// A cardio entry within a session.
model CardioLog {
  id               String         @id @default(cuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exerciseId       String?
  exercise         Exercise?      @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  durationMinutes  Float
  distanceKm       Float?
  calories         Int?
  avgSpeedKmh      Float?
  notes            String?

  @@index([workoutSessionId])
  @@index([exerciseId])
}

/// A bodyweight measurement for a user (kg). Kept long-term (not purged).
model BodyweightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg  Float
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, loggedAt])
}
